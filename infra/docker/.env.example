# Docker Compose Environment Variables
# Copy this file to .env before running docker-compose

# Redis Configuration
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# Note: Supabase services are managed via Supabase CLI
# Run: npx supabase start (from english-pro/ directory)
# Supabase CLI auto-configures PostgreSQL, GoTrue, PostgREST, Studio, etc.
# See infra/docker/README.md for details
