{
  "name": "english-pro-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "test:acceptance": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json",
    "test:acceptance:1-3": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-1-3",
    "test:acceptance:1-4": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-1-4",
    "test:acceptance:1-7": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-1-7",
    "test:acceptance:2-1": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-1",
    "test:acceptance:2-2": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-2",
    "test:acceptance:2-3": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-3",
    "test:acceptance:2-4": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-4",
    "test:acceptance:2-5": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-5",
    "test:acceptance:2-6": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-6",
    "test:acceptance:2-7": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json --testPathPatterns=story-2-7",
    "test:all": "jest && jest --config ./test/jest-integration.json && NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-acceptance.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@english-pro/shared-types": "workspace:*",
    "@google-cloud/logging-winston": "^6.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.103.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.3",
    "nest-winston": "^1.10.2",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}