// prisma/schema.prisma
// BMad English Pro - Database Schema
// Models use PascalCase (Prisma convention), tables use snake_case via @@map()

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  PARENT
  CHILD
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  EXPIRED
  CANCELLED
}

enum BadgeType {
  FIRST_CONVERSATION
  STREAK_3_DAYS
  STREAK_7_DAYS
  PRONUNCIATION_STAR
  WORDS_100
}

enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
}

enum SafetyFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================
// MODELS
// ============================================

model Parent {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId   String         @unique @map("auth_user_id") @db.Uuid
  email        String         @unique
  role         UserRole       @default(PARENT)
  displayName  String?        @map("display_name")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  children      ChildProfile[]
  subscriptions Subscription[]
  consent       ParentalConsent?

  @@index([email])
  @@index([authUserId])
  @@map("parents")
}

model ChildProfile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId          String    @map("parent_id") @db.Uuid
  displayName       String    @map("display_name")
  avatarId          Int       @default(1) @map("avatar_id")
  age               Int?
  level             String    @default("beginner")
  xpTotal           Int       @default(0) @map("xp_total")
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  lastActiveDate    DateTime? @map("last_active_date")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  parent               Parent                @relation(fields: [parentId], references: [id], onDelete: Cascade)
  conversations        ConversationSession[]
  pronunciationScores  PronunciationScore[]
  badges               Badge[]
  streak               Streak?
  xpTransactions       XpTransaction[]
  safetyFlags          SafetyFlag[]

  @@index([parentId])
  @@map("child_profiles")
}

model ConversationScenario {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String
  level            String
  topicBoundaries  Json     @map("topic_boundaries")
  maxTurns         Int      @default(10) @map("max_turns")
  promptTemplate   String   @map("prompt_template") @db.Text
  thumbnailUrl     String?  @map("thumbnail_url")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  sessions ConversationSession[]

  @@index([level])
  @@index([isActive])
  @@map("conversation_scenarios")
}

model ConversationSession {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  childId          String             @map("child_id") @db.Uuid
  scenarioId       String             @map("scenario_id") @db.Uuid
  status           ConversationStatus @default(ACTIVE)
  durationSeconds  Int                @default(0) @map("duration_seconds")
  wordsSpoken      Int                @default(0) @map("words_spoken")
  xpEarned         Int                @default(0) @map("xp_earned")
  hintsUsed        Int                @default(0) @map("hints_used")
  summaryText      String?            @map("summary_text") @db.Text
  startedAt        DateTime           @default(now()) @map("started_at")
  endedAt          DateTime?          @map("ended_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  child               ChildProfile        @relation(fields: [childId], references: [id], onDelete: Cascade)
  scenario            ConversationScenario @relation(fields: [scenarioId], references: [id])
  pronunciationScores PronunciationScore[]

  @@index([childId])
  @@index([scenarioId])
  @@index([childId, status])
  @@map("conversation_sessions")
}

model PronunciationScore {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  childId    String   @map("child_id") @db.Uuid
  word       String
  phoneme    String?
  score      Float
  errorType  String?  @map("error_type")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  session ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  child   ChildProfile        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt])
  @@index([sessionId])
  @@map("pronunciation_scores")
}

model Badge {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  childId     String    @map("child_id") @db.Uuid
  badgeType   BadgeType @map("badge_type")
  title       String
  description String?
  earnedAt    DateTime  @default(now()) @map("earned_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, badgeType])
  @@index([childId])
  @@map("badges")
}

model Streak {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  childId         String    @unique @map("child_id") @db.Uuid
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastActivityAt  DateTime? @map("last_activity_at")
  freezeCount     Int       @default(0) @map("freeze_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model XpTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  childId     String   @map("child_id") @db.Uuid
  amount      Int
  source      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt])
  @@map("xp_transactions")
}

model ParentalConsent {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId         String        @unique @map("parent_id") @db.Uuid
  status           ConsentStatus @default(PENDING)
  consentVersion   String        @map("consent_version")
  consentTimestamp DateTime?     @map("consent_timestamp")
  ipAddress        String?       @map("ip_address")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@map("parental_consents")
}

model SafetyFlag {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  childId     String              @map("child_id") @db.Uuid
  sessionId   String?             @map("session_id") @db.Uuid
  flagType    String              @map("flag_type")
  severity    SafetyFlagSeverity  @default(LOW)
  content     String?             @db.Text
  resolved    Boolean             @default(false)
  resolvedAt  DateTime?           @map("resolved_at")
  resolvedBy  String?             @map("resolved_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([severity])
  @@map("safety_flags")
}

model Subscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId             String             @map("parent_id") @db.Uuid
  planType             String             @map("plan_type")
  status               SubscriptionStatus @default(TRIAL)
  platform             String
  purchaseToken        String?            @map("purchase_token")
  startsAt             DateTime           @default(now()) @map("starts_at")
  expiresAt            DateTime?          @map("expires_at")
  gracePeriodEndsAt    DateTime?          @map("grace_period_ends_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([status])
  @@map("subscriptions")
}
