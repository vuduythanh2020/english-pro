# test/.env.test.example
# Environment variables for test execution

# Test environment identifier
TEST_ENV=test

# API base URL for e2e tests
API_BASE_URL=http://localhost:3000

# Database URL (use a separate test database!)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres_test

# Supabase (test instance)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# JWT secret for test token generation
JWT_SECRET=test-jwt-secret-for-testing-only

# Redis (test instance)
REDIS_URL=redis://localhost:6379/1

# Disable rate limiting in tests
THROTTLE_ENABLED=false
