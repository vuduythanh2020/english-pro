{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^test/support/(.*)$": "<rootDir>/test/support/$1"
  },
  "setupFiles": [
    "<rootDir>/test/support/jest-setup.ts"
  ],
  "transformIgnorePatterns": [
    "node_modules/(?!(uuid)/)"
  ]
}